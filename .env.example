# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/geomap_db

# JWT
SECRET_KEY=Enter-your-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Google Places API

GOOGLE_PLACES_API_KEY=Enter-your-google-API-key
GOOGLE_PLACES_BASE_URL=https://places.googleapis.com/v1

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_CACHE_TTL=3600
REDIS_DETAILS_CACHE_TTL=86400

# OpenAI
OPENAI_API_KEY=Enter-your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_MAX_CONTEXT_TOKENS=3000

# Pinecone
PINECONE_API_KEY=Enter-your-pinecone-api-key
PINECONE_INDEX_NAME=geo-map-places
PINECONE_ENVIRONMENT=us-east-1-aws
